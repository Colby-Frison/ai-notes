{
  "name": "ai-notes",
  "productName": "ai-notes",
  "description": "notes app with ai",
  "version": "0.0.0",
  "private": true,
  "author": "Colby Frison <colbyfrison100@gmail.com>",
  "copyright": "© 2025, Colby Frison",
  "homepage": "http://example.com",
  "main": "src/electron/main.js",
  "build": {
    "appId": "com.example.ai-notes",
    "files": [
      "src/electron/**/*",
      "app/dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "resources",
      "output": "dist"
    },
    "publish": null
  },
  "scripts": {
    "start": "npx electron .",
    "dev": "npx vite serve src/renderer --port 5173 --strictPort",
    "dev:all": "node dev.js",
    "build": "vite build src/renderer",
    "package": "npm run build && electron-builder build --publish never"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "fs-jetpack": "^4.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^13.0.1",
    "electron-builder": "^22.5.1",
    "vite": "^6.3.5"
  }
}
